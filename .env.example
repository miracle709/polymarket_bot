# Copy to .env and fill in your values. Never commit .env to git.

# Polymarket API keys (https://polymarket.com/settings → API)
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_passphrase_here
POLY_PRIVATE_KEY=your_wallet_private_key_here

# Paper trade by default — change to false for live trading
DRY_RUN=true

# Strategy tuning (optional — defaults are already sensible)
EDGE_THRESHOLD=7.0       # minimum % gap to enter (late-window strategy)
OVERREACTION_PCT=0.35    # % price move in 60s to trigger fade
FLOW_THRESHOLD=0.60      # order flow confirmation threshold

# poly_data paths (only needed if you're running poly_data alongside)
# POLY_DATA_TRADES=poly_data/processed/trades.csv
# POLY_DATA_MARKETS=poly_data/markets.csv
